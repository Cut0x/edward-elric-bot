# Edward Elric Bot - Configuration example
# Copy this file to .env and fill every value needed for your environment.

# Discord OAuth2 for the website
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=

# Edward bot
# Edward is the public card collection bot. It owns slash commands.
EDWARD_CLIENT_ID=
EDWARD_BOT_TOKEN=
EDWARD_ADD_LOGS_CHANNEL_ID=

# Backward-compatible aliases used by the website and older scripts.
# Keep these equal to Edward values unless you update the PHP integration.
DISCORD_BOT_TOKEN=

# Optional: deploy commands instantly to one test guild.
# To get Discord's "Supports Commands" bot profile badge, also deploy global commands:
# npm run deploy:edward:global
EDWARD_TEST_GUILD_ID=
DISCORD_TEST_GUILD_ID=

# Alphonse bot
# Alphonse only posts website activity to the support server.
ALPHONSE_BOT_TOKEN=
SUPPORT_GUILD_ID=
ALPHONSE_ACTIVITY_POLL_INTERVAL_MS=15000

# Alphonse channels
# Configure every activity type with its own channel. If a specific channel is empty,
# ALPHONSE_CHANNEL_ACTIVITY_ID is used as fallback.
ALPHONSE_CHANNEL_ACTIVITY_ID=
ALPHONSE_CHANNEL_LEGENDARY_ROLL_ID=
ALPHONSE_CHANNEL_FIRST_CARD_ID=
ALPHONSE_CHANNEL_COLLECTION_COMPLETE_ID=
ALPHONSE_CHANNEL_COMMUNITY_POST_ID=
ALPHONSE_CHANNEL_REPORTS_ID=

# Database
DB_HOST=localhost
DB_NAME=edwardbot
DB_USER=root
DB_PASS=

# Website
APP_URL=http://localhost/edward-elric-bot/public
APP_SECRET=change_this_to_a_long_random_secret
CARDS_URL=http://localhost/edward-elric-bot/cards

# Administration
ADMIN_DISCORD_ID=574544938440851466

# Game settings
MAX_DAILY_ROLLS=10
XP_PER_ROLL=15
