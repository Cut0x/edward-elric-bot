# =============================================
#   EDWARD ELRIC BOT - Configuration
# =============================================
# Copiez ce fichier en .env et remplissez les valeurs

# ===== DISCORD OAUTH2 (site web) =====
# Créez une application sur https://discord.com/developers/applications
# Ajoutez l'URI de redirection dans OAuth2 > Redirects
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost/edward-elric-bot/public/callback.php

# ===== DISCORD BOT =====
# Token du bot (onglet "Bot" dans votre application Discord)
DISCORD_BOT_TOKEN=
# Optionnel: ID du serveur de test pour déploiement instantané des commandes
DISCORD_TEST_GUILD_ID=

# ===== BASE DE DONNÉES =====
DB_HOST=localhost
DB_NAME=edwardbot
DB_USER=root
DB_PASS=

# ===== APPLICATION =====
# URL publique du dossier /public
APP_URL=http://localhost/edward-elric-bot/public
# Clé secrète pour les sessions PHP (changez-la !)
APP_SECRET=changez_cette_valeur_par_une_chaine_aleatoire_tres_longue

# URL d'accès aux images des cartes (dossier /cards à la racine du projet)
CARDS_URL=http://localhost/edward-elric-bot/cards

# ===== ADMINISTRATION =====
# ID Discord de l'administrateur (ne pas modifier)
ADMIN_DISCORD_ID=574544938440851466
